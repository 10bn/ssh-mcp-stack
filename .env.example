# Copy this file to .env (install.sh does this for you automatically).

# ---- MCP Bridge ----
# Bearer token that MCP clients must send as "Authorization: Bearer <token>"
# to reach the SSH MCP server through the tunnel. Leave empty and install.sh
# will generate a random one for you.
MCP_BEARER_TOKEN=

# Output transport used between the bridge and MCP clients: sse | streamableHttp
MCP_OUTPUT_TRANSPORT=sse

# ---- Cloudflare Tunnel ----
# quick  = no Cloudflare account needed, cloudflared prints a random
#          *.trycloudflare.com URL on every start (changes on restart).
# named  = stable custom hostname on your own Cloudflare zone, requires a
#          tunnel token created in the Cloudflare Zero Trust dashboard.
TUNNEL_MODE=quick

# Only required when TUNNEL_MODE=named
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_HOSTNAME=
